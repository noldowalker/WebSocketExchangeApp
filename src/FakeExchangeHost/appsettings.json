{
  "EndpointsData": [
    {
      "Name": "binance",
      "Port": 5000,
      "Resource": "/ws/binance",
      "IntervalMs": 5,
      "PayloadJsonResourceName": "binance-ticker.json"
    },
    {
      "Name": "coinbase",
      "Port": 5001,
      "Resource": "/ws/coinbase",
      "IntervalMs": 10,
      "PayloadJsonResourceName": "coinbase-ticker.json"
    },
    {
      "Name": "kraken",
      "Port": 5002,
      "Resource": "/ws/kraken",
      "IntervalMs": 15,
      "PayloadJsonResourceName": "kraken-ticker.json"
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
